#!/usr/bin/env bash
set -euo pipefail
sudo apt update
sudo apt install -y wget gpg ca-certificates
sudo install -d -m 0755 /etc/apt/keyrings

if [[ ! -f /etc/apt/keyrings/packages.mozilla.org.asc ]]; then
  wget -q https://packages.mozilla.org/apt/repo-signing-key.gpg -O- \
    | sudo tee /etc/apt/keyrings/packages.mozilla.org.asc >/dev/null
fi

echo "deb [signed-by=/etc/apt/keyrings/packages.mozilla.org.asc] https://packages.mozilla.org/apt mozilla main" \
  | sudo tee /etc/apt/sources.list.d/mozilla.list >/dev/null

cat <<'EOF' | sudo tee /etc/apt/preferences.d/mozilla >/dev/null
Package: *
Pin: origin packages.mozilla.org
Pin-Priority: 1000
EOF

# Purge wipes the snap's profile too - migrate it first if you need local state.
if snap list firefox >/dev/null 2>&1; then
  sudo snap remove --purge firefox
fi

sudo apt update
sudo apt install -y firefox