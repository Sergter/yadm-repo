#!/usr/bin/env bash
set -euo pipefail
export NVM_DIR="$HOME/.nvm"
if [[ ! -s "$NVM_DIR/nvm.sh" ]]; then
  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash
fi
# nvm is a shell function, not a binary - source it so the next lines work.
# shellcheck source=/dev/null
. "$NVM_DIR/nvm.sh"
nvm install --lts
nvm alias default 'lts/*'

# Azure Artifacts npm credential provider - transparent OAuth for internal
# npm feeds. Don't fail the whole bootstrap if the registry is unreachable.
npm install --global @microsoft/artifacts-npm-credprovider \
  --registry https://pkgs.dev.azure.com/artifacts-public/23934c1b-a3b5-4b70-9dd3-d1bef4cc72a0/_packaging/AzureArtifacts/npm/registry/ || true