#!/usr/bin/env bash
set -euo pipefail
# Git identity and GCM settings are tracked in the yadm-managed ~/.gitconfig.
# Bootstrap only needs to ensure the GCM binary is present.
if [[ ! -x /usr/local/bin/git-credential-manager ]]; then
  curl -fsSL https://aka.ms/gcm/linux-install-source.sh | sh -s -- -y
fi