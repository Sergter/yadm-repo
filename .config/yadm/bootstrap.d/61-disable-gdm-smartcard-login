#!/usr/bin/env bash
set -euo pipefail

TARGET=/etc/gdm3/greeter.dconf-defaults
TMP="$(mktemp)"
trap 'rm -f "$TMP"' EXIT

awk '
  BEGIN {
    in_section = 0
    inserted = 0
  }

  /^\[org\/gnome\/login-screen\]$/ {
    in_section = 1
    print
    next
  }

  /^\[/ {
    if (in_section && !inserted) {
      print "enable-smartcard-authentication=false"
      inserted = 1
    }
    in_section = 0
    print
    next
  }

  {
    if (in_section && $0 ~ /^#?[[:space:]]*enable-smartcard-authentication=/) {
      if (!inserted) {
        print "enable-smartcard-authentication=false"
        inserted = 1
      }
      next
    }

    print
  }

  END {
    if (in_section && !inserted) {
      print "enable-smartcard-authentication=false"
      inserted = 1
    }

    if (!inserted) {
      print ""
      print "[org/gnome/login-screen]"
      print "enable-smartcard-authentication=false"
    }
  }
' "$TARGET" >"$TMP"

if ! cmp -s "$TMP" "$TARGET"; then
  sudo install -m 0644 "$TMP" "$TARGET"

  if systemctl is-active --quiet gdm.service; then
    sudo systemctl reload gdm.service
  fi
fi