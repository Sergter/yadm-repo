#!/usr/bin/env bash
set -euo pipefail
TARGET=/etc/pam.d/common-password
# minlen=12 + 1 of each char class (digit, other, upper, lower) is the policy
# enforced by the same device-compliance rules Himmelblau applies.
NEW='password requisite         pam_pwquality.so retry=3 dcredit=-1 ocredit=-1 ucredit=-1 lcredit=-1 minlen=12'
if ! grep -qF "$NEW" "$TARGET"; then
  # Always back up before mutating a PAM file - a broken PAM locks you out.
  sudo cp "$TARGET" "$TARGET.bak.$(date +%s)"
  # Replace the existing pam_pwquality line in place...
  sudo sed -i -E 's|^password\s+requisite\s+pam_pwquality\.so.*|'"$NEW"'|' "$TARGET"
  # ...or append it if there was no such line to begin with.
  grep -q '^password\s\+requisite\s\+pam_pwquality\.so' "$TARGET" \
    || echo "$NEW" | sudo tee -a "$TARGET" >/dev/null
fi